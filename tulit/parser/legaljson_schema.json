{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "LegalJSON",
    "type": "object",
    "properties": {
        "preface": {
            "type": [
                "string",
                "null"
            ]
        },
        "preamble": {
            "type": [
                "string",
                "null"
            ]
        },
        "formula": {
            "type": [
                "string",
                "null"
            ]
        },
        "citations": {
            "type": "array",
            "items": {
                "type": [
                    "object",
                    "string"
                ]
            }
        },
        "recitals": {
            "type": "array",
            "items": {
                "type": [
                    "object",
                    "string"
                ]
            }
        },
        "preamble_final": {
            "type": [
                "string",
                "null"
            ]
        },
        "chapters": {
            "type": "array",
            "items": {
                "type": [
                    "object",
                    "string"
                ]
            }
        },
        "articles": {
            "type": "array",
            "items": {
                "type": "object"
            },
            "description": "Articles of the legal act. Children have eId (NNN.NNN), text, and the same structured 'amendment' field as annex children (null when the paragraph does not amend another act)."
        },
        "conclusions": {
            "type": [
                "object",
                "null"
            ]
        },
        "annexes": {
            "type": "array",
            "description": "Annexes of the legal act, uniform with articles: eId, num, heading and children. Each child has eId (NNN.NNN), text (full readable text), and amendment — null for ordinary content, or a structured object {action: replace|insert|add|delete|amend|null, instruction, amended_act, quoted: [{kind: structure, children: [...]} | {kind: text, text}]} modelled on Akoma Ntoso mod/quotedText/quotedStructure. Tables carry a 'table' key with caption, rows and notes.",
            "items": {
                "type": "object"
            }
        }
    },
    "required": [
        "preface",
        "citations",
        "recitals",
        "chapters",
        "articles"
    ]
}