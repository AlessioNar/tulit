{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LegalJSON",
  "type": "object",
  "properties": {
    "preface": {"type": ["string", "null"]},
    "preamble": {"type": ["string", "null"]},
    "formula": {"type": ["string", "null"]},
    "citations": {
      "type": "array",
      "items": {"type": ["object", "string"]}
    },
    "recitals": {
      "type": "array",
      "items": {"type": ["object", "string"]}
    },
    "preamble_final": {"type": ["string", "null"]},
    "chapters": {
      "type": "array",
      "items": {"type": ["object", "string"]}
    },
    "articles": {
      "type": "array",
      "items": {"type": "object"}
    },
    "conclusions": {"type": ["object", "null"]},
    "digital_dimensions": {
      "type": ["object", "null"],
      "properties": {
        "number": {"type": ["string", "null"]},
        "heading": {"type": "string"},
        "subsections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "number": {"type": ["string", "null"]},
              "heading": {"type": "string"},
              "tables": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "title": {"type": ["string", "null"]},
                    "headers": {"type": "array", "items": {"type": "string"}},
                    "rows": {"type": "array", "items": {"type": "array", "items": {"type": "string"}}}
                  }
                }
              },
              "text_content": {"type": "array", "items": {"type": "string"}}
            }
          }
        }
      }
    }
  },
  "required": ["preface", "citations", "recitals", "chapters", "articles"]
}
