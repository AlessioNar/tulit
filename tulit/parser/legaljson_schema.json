{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "LegalJSON",
    "type": "object",
    "properties": {
        "preface": {
            "type": [
                "string",
                "null"
            ]
        },
        "preamble": {
            "type": [
                "string",
                "null"
            ]
        },
        "formula": {
            "type": [
                "string",
                "null"
            ]
        },
        "citations": {
            "type": "array",
            "items": {
                "type": [
                    "object",
                    "string"
                ]
            }
        },
        "recitals": {
            "type": "array",
            "items": {
                "type": [
                    "object",
                    "string"
                ]
            }
        },
        "preamble_final": {
            "type": [
                "string",
                "null"
            ]
        },
        "chapters": {
            "type": "array",
            "items": {
                "type": [
                    "object",
                    "string"
                ]
            }
        },
        "articles": {
            "type": "array",
            "items": {
                "type": "object"
            }
        },
        "conclusions": {
            "type": [
                "object",
                "null"
            ]
        },
        "annexes": {
            "type": "array",
            "description": "Annexes of the legal act, uniform with articles: eId, num, heading and children (para_N blocks with text and amendment flag; tables carry structured rows)",
            "items": {
                "type": "object"
            }
        }
    },
    "required": [
        "preface",
        "citations",
        "recitals",
        "chapters",
        "articles"
    ]
}